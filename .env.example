# ─────────────────────────────────────────────────────────────────────────────
# Agent Swarm Studio — Business Intelligence Swarm
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: LLM API keys ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Claude OAuth (used by claude-proxy for token-based auth) ──────
# If set, the claude-proxy service exchanges this for short-lived API tokens.
# Leave blank to use ANTHROPIC_API_KEY directly.
ANTHROPIC_OAUTH_KEY=

# ── Required: Database credentials ─────────────────────────────────────────
POSTGRES_USER=agentuser
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=agents
DATABASE_URL=postgresql://agentuser:changeme_secure_password@postgres:5432/agents

# ── Required: Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Shared URL Context ───────────────────────────────────────────────────────
# Set this to the company URL you want all agents to analyze
# Can also be set per-task via the API (context.company_url field)
TARGET_COMPANY_URL=https://example.com

# Optional: Comma-separated list of URLs for daily watchlist refresh
WATCHED_COMPANY_URLS=https://company1.com,https://company2.com

# ── agent-search-tool configuration ─────────────────────────────────────────
# Configure via: docker exec agent-lawyer agent-search configure
# Or pre-configure with these env vars:
# EXA_API_KEY=               # Exa search API (recommended)
# GITHUB_TOKEN=              # GitHub API token for deeper repo search

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
